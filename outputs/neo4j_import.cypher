// Neo4j Cypher commands to import ADA-Attivita-SEP graph
// Generated from NetworkX graph

// Create constraints for unique node IDs
CREATE CONSTRAINT ada_code IF NOT EXISTS FOR (a:ADA) REQUIRE a.code IS UNIQUE;
CREATE CONSTRAINT attivita_id IF NOT EXISTS FOR (att:Attivita) REQUIRE att.id IS UNIQUE;
CREATE CONSTRAINT sep_code IF NOT EXISTS FOR (s:SEP) REQUIRE s.code IS UNIQUE;

// Create indexes for better performance
CREATE INDEX ada_label IF NOT EXISTS FOR (a:ADA) ON (a.label);
CREATE INDEX sep_label IF NOT EXISTS FOR (s:SEP) ON (s.label);

// Create ADA nodes
MERGE (a:ADA {code: 'ADA.QE.01.01', label: 'ADA.QE.01.01', title: 'ADA: None'});
